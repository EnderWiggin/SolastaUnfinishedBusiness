# OpenAI Compatible API Configuration for Translation Script
# Copy this file to .env and fill in your actual values

# API endpoint URL (e.g., https://api.openai.com/v1 for OpenAI)
API_BASE_URL=https://api.openai.com/v1

# Your API key
API_KEY=your-api-key-here

# Model ID to use for translation (e.g., gpt-4, gpt-3.5-turbo, or other compatible models)
MODEL_ID=gpt-4

# Number of translation entries to process in a single API call (default: 10)
# Larger batches are more efficient but may hit token limits
BATCH_SIZE=10

# Maximum retries for failed API calls (default: 3)
MAX_RETRIES=3

# Delay between retries in seconds (default: 2)
RETRY_DELAY=2

# Maximum number of concurrent translation workers (default: 3)
# Higher values = faster translation but more API load
# Recommended: 3-5 for most APIs to avoid rate limiting
MAX_WORKERS=3
